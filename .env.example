# Скопируйте в .env и подставьте свой ключ (файл .env не коммитится)
OPENAI_API_KEY=

# Публичный URL бэкенда (для ссылок редактора из расширения)
# Локально:
# BACKEND_PUBLIC_URL=http://127.0.0.1:8000
# Сервер Цюрих (пример):
# BACKEND_PUBLIC_URL=http://194.87.96.144:8012
# API_PORT=8012

# Локально можно не задавать — используются пути по умолчанию в backend/
# DATABASE_URL=sqlite:///backend/data/training_recorder.db
# STORAGE_ROOT=backend/storage

# Опционально: модели и лимиты
# GENERATE_MODEL=gpt-4o-mini
# VISION_MODEL=gpt-4o-mini
# VISION_BUDGET_PER_RECORDING=5

# Docker compose
# API_PORT=8000
